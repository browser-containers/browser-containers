{
  "name": "browser-containers",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "validate": "bash -c 'echo -n \"Format: \"; (oxfmt --check packages/*/src 2>/dev/null && echo \"✅\") || echo \"❌\"; echo -n \"Lint: \"; (oxlint packages/*/src 2>/dev/null && echo \"✅\") || echo \"❌\"; echo -n \"Typecheck: \"; (tsc --noEmit 2>/dev/null && echo \"✅\") || echo \"❌\"'",
    "clean": "rm -rf dist packages/*/dist node_modules/.cache .turbo",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "test:e2e": "pnpm --filter @browser-containers/e2e test",
    "test:e2e:verbose": "pnpm --filter @browser-containers/e2e test:verbose",
    "docs:internal": "docmd dev --cwd .agents",
    "docs:internal:build": "docmd build --cwd .agents"
  },
  "devDependencies": {
    "@docmd/core": "^0.8.12",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.0.0",
    "playwright-core": "^1.59.1",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "license": "Apache-2.0"
}
