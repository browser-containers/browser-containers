{
  "name": "@bolojs/node-web-shims",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    },
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "threads.js": "^0.6.1",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "pathe": "^1.1.2",
    "unenv": "2.0.0-rc.24"
  },
  "license": "Apache-2.0"
}
