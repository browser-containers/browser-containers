{
  "name": "@browser-containers/demo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "portless run --name browser-containers --force vite",
    "preview": "portless run --name browser-containers --force vite preview",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@browser-containers/node-web-shims": "workspace:*",
    "@browser-containers/npm": "workspace:*",
    "@browser-containers/runtime": "workspace:*",
    "@browser-containers/sw-sandbox": "workspace:*",
    "@browser-containers/vfs-bus": "workspace:*",
    "@browser-containers/vite-server": "workspace:*",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "solid-js": "^1.9.0",
    "unenv": "^1.10.0"
  },
  "devDependencies": {
    "portless": "latest",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-solid": "^2.11.0"
  },
  "license": "Apache-2.0"
}
