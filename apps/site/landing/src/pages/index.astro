---
import BaseLayout from '../layouts/BaseLayout.astro';

const defaultCode = 'console.log("hello")';
const title = 'browser-containers — Node.js in the browser';
const description = 'A fully client-side Node.js runtime. Run Node.js applications in the browser with zero server dependency.';
---

<BaseLayout title={title} description={description}>
  <section class="hero" aria-label="Introduction">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="node-wordmark">Node.js</div>
        <h1>Run Node.js in the browser.</h1>
        <p class="tagline">Zero-config Node.js runtime for browsers. No server. No build step.</p>
        <div class="cta-group">
          <a href="/docs/getting-started" class="button button-primary">Get Started</a>
          <a href="https://github.com/browser-containers/browser-containers" target="_blank" rel="noopener noreferrer" class="button button-secondary">View on GitHub</a>
        </div>
      </div>

      <section class="playground" aria-label="Playground">
        <div class="terminal" id="playground-shell">
          <div class="terminal-header">
            <div class="terminal-dots">
              <span class="terminal-dot red"></span>
              <span class="terminal-dot yellow"></span>
              <span class="terminal-dot green"></span>
            </div>
            <span class="terminal-title">node-repl</span>
          </div>

          <div class="terminal-body">
            <p class="sabs-warning" id="sabs-warning" hidden>
              Your browser context doesn't expose SharedArrayBuffer — some features may be limited.
            </p>

            <div class="playground-panels">
              <div class="editor-panel">
                <label for="editor" class="panel-label">Editor</label>
                <div class="editor-host" id="editor-host">
                  <textarea id="editor" class="editor-fallback" spellcheck="false">{defaultCode}</textarea>
                </div>
              </div>

              <div class="terminal-panel">
                <span class="panel-label">Terminal</span>
                <div class="terminal-host" id="terminal-host">
                  <div class="terminal-placeholder" aria-hidden="true">
                    <span class="repl-line">
                      <span class="repl-prompt">$</span>
                      <span class="repl-command">node -e "console.log('hello')"</span>
                    </span>
                    <span class="repl-output">hello</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="terminal-footer">
            <button class="run-button" id="run-btn" type="button">Run</button>
          </div>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<script>
  const shell = document.getElementById('playground-shell');
  if (!shell) throw new Error('Playground shell not found');

  const editorHost = shell.querySelector('#editor-host') as HTMLElement;
  const terminalHost = shell.querySelector('#terminal-host') as HTMLElement;
  const runBtn = shell.querySelector('#run-btn') as HTMLButtonElement;
  const sabsWarning = shell.querySelector('#sabs-warning') as HTMLElement;
  const editor = shell.querySelector('#editor') as HTMLTextAreaElement;
  const defaultCode = editor?.value ?? 'console.log("hello")';

  runBtn.addEventListener(
    'click',
    async function onFirstRun() {
      runBtn.disabled = true;
      runBtn.textContent = 'Loading...';
      try {
        const { initPlayground } = await import('../scripts/playground.js');
        const run = await initPlayground({ editorHost, terminalHost, runBtn, sabsWarning, defaultCode });
        runBtn.textContent = 'Run';
        runBtn.disabled = false;
        run();
      } catch (err) {
        console.error('Playground failed to load:', err);
        runBtn.textContent = 'Error';
      }
    },
    { once: true },
  );
</script>

<style>
  .hero {
    --terminal-bg: #111111;
    --terminal-green: #22c55e;

    background-color: var(--bg);
    color: var(--fg);
    display: flex;
    align-items: center;
    min-height: 80vh;
    padding-block: 4rem 3rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-copy {
    text-align: center;
  }

  .node-wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .node-wordmark::before {
    content: '⬢';
    color: var(--terminal-green);
    font-size: 1rem;
  }

  .hero-copy h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .tagline {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: var(--muted);
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .button-primary {
    background-color: var(--fg);
    color: var(--bg);
    border: 1px solid var(--fg);
  }

  .button-primary:hover {
    background-color: transparent;
    color: var(--fg);
    text-decoration: none;
  }

  .button-secondary {
    background-color: transparent;
    color: var(--fg);
    border: 1px solid var(--border);
  }

  .button-secondary:hover {
    border-color: var(--fg);
    text-decoration: none;
  }

  .playground {
    width: 100%;
  }

  .terminal {
    width: 100%;
    background-color: var(--terminal-bg);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    background-color: rgba(255, 255, 255, 0.02);
  }

  .terminal-dots {
    display: flex;
    gap: 0.5rem;
  }

  .terminal-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
  }

  .terminal-dot.red {
    background-color: #ff5f56;
  }

  .terminal-dot.yellow {
    background-color: #ffbd2e;
  }

  .terminal-dot.green {
    background-color: #27c93f;
  }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .terminal-body {
    display: flex;
    flex-direction: column;
  }

  .sabs-warning {
    margin: 0;
    padding: 0.75rem 1rem;
    font-size: 0.8125rem;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
  }

  .playground-panels {
    display: grid;
    grid-template-columns: 1fr;
    height: 360px;
  }

  .editor-panel,
  .terminal-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .editor-panel {
    border-bottom: 1px solid var(--border);
  }

  .panel-label {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    pointer-events: none;
  }

  .editor-host,
  .terminal-host {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .editor-fallback,
  .terminal-fallback {
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    padding: 1rem;
    resize: none;
    outline: none;
  }

  .editor-fallback:focus {
    box-shadow: inset 0 0 0 1px var(--border);
  }

  .terminal-placeholder {
    height: 100%;
    padding: 1rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .repl-line {
    display: flex;
    gap: 0.5rem;
  }

  .repl-prompt {
    color: var(--terminal-green);
    user-select: none;
  }

  .repl-command {
    color: var(--fg);
  }

  .repl-output {
    color: var(--muted);
  }

  .terminal-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--border);
    background-color: rgba(255, 255, 255, 0.02);
  }

  .run-button {
    background-color: var(--terminal-green);
    color: #0a0a0a;
    border: 1px solid var(--terminal-green);
    font-weight: 600;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
  }

  .run-button:hover:not(:disabled) {
    background-color: transparent;
    color: var(--terminal-green);
  }

  .run-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
    }

    .hero-copy {
      text-align: left;
    }

    .cta-group {
      justify-content: flex-start;
    }

    .playground-panels {
      grid-template-columns: 1fr 1fr;
      height: 400px;
    }

    .editor-panel {
      border-bottom: none;
      border-right: 1px solid var(--border);
    }
  }

  @media (min-width: 1024px) {
    .hero-grid {
      gap: 4rem;
    }

    .playground-panels {
      height: 420px;
    }
  }
</style>
