---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Button } from '../../../shared/components/ui/button.tsx';

const title = 'browser-containers — Node.js in the browser';
const description = 'A fully client-side Node.js runtime. Run Node.js applications in the browser with zero server dependency.';
---

<BaseLayout title={title} description={description}>
  <section
    class="flex min-h-[85vh] items-center bg-bg bg-[radial-gradient(var(--border)_1px,transparent_1px)] bg-[length:24px_24px] py-28 text-fg md:py-32"
    aria-label="Introduction"
  >
    <div class="container grid grid-cols-1 items-center gap-12 md:grid-cols-[1.1fr_1fr] lg:gap-16">
      <div class="hero-in text-left">
        <span
          class="hero-item mb-6 inline-block rounded-full border border-border px-3 py-1 font-mono text-[0.6875rem] font-medium uppercase tracking-[0.2em] text-muted"
          style="animation-delay: 0ms"
        >
          Zero server. Zero build step.
        </span>
        <h1
          class="hero-item mb-6 text-[clamp(2.75rem,6vw,5.5rem)] leading-[0.98] font-bold tracking-[-0.04em]"
          style="animation-delay: 90ms"
        >
          Run Node.js<br />in the browser.
        </h1>
        <p
          class="hero-item mb-9 max-w-[32ch] text-[clamp(1.125rem,2vw,1.375rem)] leading-relaxed text-muted"
          style="animation-delay: 180ms"
        >
          Zero-config Node.js runtime for browsers. No server. No build step.
        </p>
        <div class="hero-item flex flex-wrap justify-start gap-4" style="animation-delay: 270ms">
          <Button client:load href="/docs/" variant="primary">
            <span>Get Started</span>
            <span class="flex size-6 items-center justify-center rounded-full bg-bg/10 transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-0.5">
              <svg class="size-3.5" viewBox="0 0 256 256" fill="none" aria-hidden="true">
                <path d="M40 128h176M144 56l72 72-72 72" stroke="currentColor" stroke-width="20" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </span>
          </Button>
          <Button
            client:load
            href="https://github.com/browser-containers/browser-containers"
            target="_blank"
            rel="noopener noreferrer"
            variant="secondary"
          >
            View on GitHub
          </Button>
        </div>
      </div>

      <section class="hero-item w-full" style="animation-delay: 180ms" aria-label="Live demo">
        <div class="rounded-2xl bg-[linear-gradient(160deg,var(--border),transparent_60%)] p-2 shadow-[0_24px_80px_rgba(0,0,0,0.35)]">
          <div class="flex h-[420px] flex-col overflow-hidden rounded-xl border border-border bg-[#111111] shadow-[inset_0_1px_1px_rgba(255,255,255,0.08)]">
            <div class="flex shrink-0 items-center gap-3 border-b border-border bg-white/[0.02] px-4 py-3">
              <div class="flex gap-2">
                <span class="size-3 rounded-full bg-[#ff5f56]"></span>
                <span class="size-3 rounded-full bg-[#ffbd2e]"></span>
                <span class="size-3 rounded-full bg-[#27c93f]"></span>
              </div>
              <span class="flex-1 text-center font-mono text-[0.8125rem] text-muted">demo</span>
            </div>
            <iframe class="flex-1 w-full border-0" src="/demo" title="browser-containers live demo" loading="lazy"></iframe>
          </div>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  /* Above-the-fold hero, so entrance is a simple on-load stagger rather than
     an IntersectionObserver scroll reveal (there's nothing to scroll to). */
  .hero-item {
    animation: hero-in 800ms cubic-bezier(0.32, 0.72, 0, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-item {
      animation: none;
    }
  }

  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
