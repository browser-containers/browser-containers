---
import '../styles/global.css';
import Navbar from '../../../shared/components/Navbar.astro';
import Footer from '../../../shared/components/Footer.astro';
import ThemeInit from '../../../shared/components/ThemeInit.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Browser-based Node.js runtime. Run Node.js in the browser with zero server dependency.' } = Astro.props;

const links = [
  { href: '/docs', label: 'Docs' },
  { href: '/compat', label: 'Are We Web Yet?' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <ThemeInit />
  </head>
  <body>
    <slot name="navbar">
      <Navbar links={links} />
    </slot>

    <main>
      <slot />
    </main>

    <slot name="footer">
      <Footer />
    </slot>
  </body>
</html>
