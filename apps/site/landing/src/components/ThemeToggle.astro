<button type="button" class="theme-toggle" aria-label="Toggle dark mode" data-theme-toggle>
  <span class="theme-toggle-sun" aria-hidden="true">☀</span>
  <span class="theme-toggle-moon" aria-hidden="true">☾</span>
</button>

<script is:inline>
  (function () {
    const button = document.querySelector('[data-theme-toggle]');
    if (!button) return;

    function apply(theme) {
      document.documentElement.dataset.theme = theme;
      localStorage.setItem('theme', theme);
    }

    button.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme;
      const next = current === 'dark' ? 'light' : 'dark';
      apply(next);
    });
  })();
</script>

<style is:global>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border-radius: 9999px;
    line-height: 1;
  }

  .theme-toggle-sun,
  .theme-toggle-moon {
    position: absolute;
  }

  :root .theme-toggle-moon {
    display: none;
  }

  :root .theme-toggle-sun {
    display: inline;
  }

  [data-theme="dark"] .theme-toggle-sun {
    display: none;
  }

  [data-theme="dark"] .theme-toggle-moon {
    display: inline;
  }
</style>
