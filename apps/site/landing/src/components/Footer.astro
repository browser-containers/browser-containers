---
const links = [
  { href: '/docs', label: 'Docs' },
  { href: '/compat', label: 'Are We Web Yet?' },
  { href: 'https://github.com/browser-containers/browser-containers', label: 'GitHub' },
];
---

<footer class="footer">
  <div class="container footer-inner">
    <nav class="footer-links" aria-label="footer">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="footer-link"
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <p class="footer-copy">Browser-containers — Node.js in the browser.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-block: 1.75rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    font-size: 0.875rem;
  }

  .footer-link {
    color: var(--muted);
  }

  .footer-link:hover {
    color: var(--fg);
  }

  .footer-copy {
    color: var(--muted);
    font-size: 0.75rem;
    font-family: var(--font-mono);
  }

  @media (min-width: 640px) {
    .footer-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
