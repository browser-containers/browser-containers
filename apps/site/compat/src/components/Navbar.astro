---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
const links = [
  { href: '/docs', label: 'docs' },
  { href: '/compat', label: 'compat' },
];
---

<header class="navbar">
  <div class="container navbar-inner">
    <a href="/" class="wordmark" aria-label="browser-containers home">
      <span class="mark" aria-hidden="true">◈</span>
      <span class="wordmark-text">browser-containers</span>
    </a>

    <nav class="nav-links" aria-label="primary">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath === link.href || currentPath === `${link.href}/` }]}
            aria-current={currentPath === link.href || currentPath === `${link.href}/` ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://github.com/browser-containers/browser-containers"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link"
      >
        GitHub
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .navbar {
    border-bottom: 1px solid var(--border);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1rem;
    flex-wrap: wrap;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .mark {
    font-size: 1.25rem;
    line-height: 1;
  }

  .wordmark-text {
    display: none;
  }

  @media (min-width: 640px) {
    .wordmark-text {
      display: inline;
    }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
  }

  .nav-link {
    color: var(--muted);
    padding: 0.25rem 0.375rem;
  }

  .nav-link:hover {
    color: var(--fg);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  @media (min-width: 640px) {
    .nav-links {
      gap: 1.25rem;
    }
  }
</style>
