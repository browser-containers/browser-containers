---
import CompatLayout from '../layouts/CompatLayout.astro';
import SearchCommand from '../components/SearchCommand.astro';
import { HeatCalendar } from '../components/HeatCalendar.tsx';
import data from '../data/packages.json';
import latest from '../data/latest.json';
import { getHeadlineStat, getPackageCount } from '../lib/stats';

const { categories, rows } = data;
const stat = getHeadlineStat();
const packageCount = getPackageCount();
---

<CompatLayout title="Compatibility">
  <header class="compat-hero bento">
    <div class="bento-cell bento-cell--headline">
      <h1>ARE WE WEB YET?</h1>
      <p class="lead">Tracking browser, runtime, and package support across {packageCount} Node.js APIs and libraries.</p>
    </div>

    <div class="bento-cell bento-cell--stat">
      <span class="stat-value">{stat.percent}%</span>
      <span class="stat-label">{stat.supported} of {stat.total} checks supported in-browser today</span>
    </div>
  </header>

  <SearchCommand />

  <div class="compat-main" id="compat-grid">
    <div class="bezel-outer">
      <div class="grid-wrapper">
        <HeatCalendar
          client:visible
          categories={categories}
          rows={rows}
          latest={latest}
        />
      </div>
    </div>
  </div>
</CompatLayout>
