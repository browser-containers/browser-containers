---
import '../styles/global.css';
import '../styles/compat.css';
import Navbar from '../components/Navbar.astro';
import ThemeInit from '../components/ThemeInit.astro';

interface Props {
  title?: string;
}

const { title = 'Compatibility' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ThemeInit />
    <slot name="head" />
  </head>
  <body>
    <Navbar />
    <main class="container compat-page">
      <slot />
    </main>
  </body>
</html>
