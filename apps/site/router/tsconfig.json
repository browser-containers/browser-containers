{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["functions/**/*", "wrangler.jsonc"]
}
