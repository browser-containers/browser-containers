{
  "name": "@bolojs/compat-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "compat-harness": "./bin/cli.js"
  },
  "scripts": {
    "build": "vite build",
    "dev": "portless run --name compat-harness --force vite",
    "preview": "portless run --name compat-harness --force vite preview",
    "cli": "node bin/cli.js",
    "lint": "oxlint src bin",
    "format": "oxfmt --check src bin",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bolojs/node-web-shims": "workspace:*",
    "@bolojs/runtime": "workspace:*"
  },
  "devDependencies": {
    "playwright-core": "^1.59.1",
    "portless": "latest",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "license": "Apache-2.0"
}
