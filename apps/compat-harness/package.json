{
  "name": "@browser-containers/compat-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "portless run --name compat-harness --force vite",
    "preview": "portless run --name compat-harness --force vite preview",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@browser-containers/node-web-shims": "workspace:*",
    "@browser-containers/runtime": "workspace:*"
  },
  "devDependencies": {
    "portless": "latest",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "license": "Apache-2.0"
}
